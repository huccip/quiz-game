    <string name="guide_how_to_play">How to Play</string>
    <string name="guide_tutorial_title">How to Play Quiz Game</string>
    
    <string name="guide_step_1_title">Choose a Category</string>
    <string name="guide_step_1_desc">Tap on a fun category that interests you!</string>
    
    <string name="guide_step_2_title">Answer Questions</string>
    <string name="guide_step_2_desc">Read each question carefully and select the correct answer before time runs out!</string>
    
    <string name="guide_step_3_title">Earn Points</string>
    <string name="guide_step_3_desc">Get points for correct answers. The faster you answer, the more points you get!</string>
    
    <string name="guide_step_4_title">Win Trophies</string>
    <string name="guide_step_4_desc">Collect trophies for completing quizzes with high scores!</string>
    
