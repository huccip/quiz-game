    <string name="guide_utility_hint_card">Hint Card</string>
    <string name="guide_utility_hint_card_desc">Removes one wrong answer from choices</string>
    
    <string name="guide_utility_double_points">Double Points</string>
    <string name="guide_utility_double_points_desc">Doubles the points you earn for a correct answer</string>
    
    <string name="guide_utility_second_chance">Second Chance</string>
    <string name="guide_utility_second_chance_desc">Allows you to retry a question if you get it wrong</string>
    
