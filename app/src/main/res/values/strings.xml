    <string name="guide_welcome_title">Welcome to Quiz Game!</string>
    <string name="guide_welcome_subtitle">Let\'s learn how to play and have fun!</string>
    
    <string name="guide_how_to_play">How to Play</string>
    <string name="guide_tutorial_title">How to Play Quiz Game</string>
    
    <string name="guide_step_1_title">Choose a Category</string>
    <string name="guide_step_1_desc">Tap on a fun category that interests you!</string>
    
    <string name="guide_step_2_title">Answer Questions</string>
    <string name="guide_step_2_desc">Read each question carefully and select the correct answer before time runs out!</string>
    
    <string name="guide_step_3_title">Earn Points</string>
    <string name="guide_step_3_desc">Get points for correct answers. The faster you answer, the more points you get!</string>
    
    <string name="guide_step_4_title">Win Trophies</string>
    <string name="guide_step_4_desc">Collect trophies for completing quizzes with high scores!</string>
    
    <string name="guide_utility_cards">Utility Cards</string>
    
    <string name="guide_utility_time_booster">Time Booster</string>
    <string name="guide_utility_time_booster_desc">Gives you extra time to answer questions</string>
    
    <string name="guide_utility_hint_card">Hint Card</string>
    <string name="guide_utility_hint_card_desc">Removes one wrong answer from choices</string>
    
    <string name="guide_utility_double_points">Double Points</string>
    <string name="guide_utility_double_points_desc">Doubles the points you earn for a correct answer</string>
    
    <string name="guide_utility_second_chance">Second Chance</string>
    <string name="guide_utility_second_chance_desc">Allows you to retry a question if you get it wrong</string>
    
