    android:width="240dp"
    android:height="180dp"
    android:viewportWidth="240"
    android:viewportHeight="180">

    <!-- ===== OUTER AMBIENT GLOW ===== -->
    <path android:pathData="M120,90m-90,0a90,90 0,1,1 180,0a90,90 0,1,1 -180,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="120"
                android:centerY="90"
                android:gradientRadius="90">
                <item android:offset="0" android:color="#338B5CF6"/>
                <item android:offset="0.5" android:color="#1A6366F1"/>
                <item android:offset="1" android:color="#00000000"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ===== INNER GLOW ===== -->
    <path android:pathData="M120,90m-50,0a50,50 0,1,1 100,0a50,50 0,1,1 -100,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="120"
                android:centerY="90"
                android:gradientRadius="50">
                <item android:offset="0" android:color="#448B5CF6"/>
                <item android:offset="1" android:color="#00000000"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ===== CENTRAL GRID — 4 CATEGORY TILES ===== -->
    <!-- Top-left tile (indigo) -->
    <path android:pathData="M88,60 L112,60 Q114,60 114,62 L114,86 Q114,88 112,88 L88,88 Q86,88 86,86 L86,62 Q86,60 88,60 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="86"
                android:startY="60"
                android:endX="114"
                android:endY="88">
                <item android:offset="0" android:color="#FF6366F1"/>
                <item android:offset="1" android:color="#FF4F46E5"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- Icon in top-left: brain/lightbulb dot -->
    <path android:pathData="M100,74m-5,0a5,5 0,1,1 10,0a5,5 0,1,1 -10,0"
        android:fillColor="#C7D2FE" android:fillAlpha="0.8"/>
    <path android:pathData="M100,68 L100,65"
        android:strokeColor="#C7D2FE" android:strokeWidth="1.5" android:strokeAlpha="0.6"/>

    <!-- Top-right tile (cyan) -->
    <path android:pathData="M128,60 L152,60 Q154,60 154,62 L154,86 Q154,88 152,88 L128,88 Q126,88 126,86 L126,62 Q126,60 128,60 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="126"
                android:startY="60"
                android:endX="154"
                android:endY="88">
                <item android:offset="0" android:color="#FF06B6D4"/>
                <item android:offset="1" android:color="#FF0891B2"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- Icon in top-right: atom/science circles -->
    <path android:pathData="M140,74m-4,0a4,4 0,1,1 8,0a4,4 0,1,1 -8,0"
        android:fillColor="#A5F3FC" android:fillAlpha="0.8"/>
    <path android:pathData="M140,74m-8,0a8,4 0,1,1 16,0a8,4 0,1,1 -16,0"
        android:strokeColor="#A5F3FC" android:strokeWidth="0.8" android:fillColor="#00000000" android:strokeAlpha="0.5"/>

    <!-- Bottom-left tile (purple) -->
    <path android:pathData="M88,100 L112,100 Q114,100 114,102 L114,126 Q114,128 112,128 L88,128 Q86,128 86,126 L86,102 Q86,100 88,100 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="86"
                android:startY="100"
                android:endX="114"
                android:endY="128">
                <item android:offset="0" android:color="#FF8B5CF6"/>
                <item android:offset="1" android:color="#FF7C3AED"/>
