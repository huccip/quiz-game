    <path android:pathData="M30,90m-2,0a2,2 0,1,1 4,0a2,2 0,1,1 -4,0"
        android:fillColor="#22D3EE" android:fillAlpha="0.5"/>
    <path android:pathData="M210,85m-2,0a2,2 0,1,1 4,0a2,2 0,1,1 -4,0"
        android:fillColor="#C4B5FD" android:fillAlpha="0.6"/>
    <path android:pathData="M160,30m-2,0a2,2 0,1,1 4,0a2,2 0,1,1 -4,0"
        android:fillColor="#818CF8" android:fillAlpha="0.4"/>
    <path android:pathData="M80,30m-2,0a2,2 0,1,1 4,0a2,2 0,1,1 -4,0"
        android:fillColor="#0D9488" android:fillAlpha="0.5"/>

    <!-- ===== SPARKLE STARS ===== -->
    <path android:pathData="M65,80 L67,74 L69,80 L75,82 L69,84 L67,90 L65,84 L59,82 Z"
