    <path android:pathData="M155,42 L156,40 L157,42 L159,43 L157,44 L156,46 L155,44 L153,43 Z"
        android:fillColor="#67E8F9" android:fillAlpha="0.6"/>

    <!-- ===== QUESTION MARK (floating, subtle) ===== -->
    <path android:pathData="M68,110 Q68,105 72,103 Q76,101 78,104 Q80,107 75,110"
        android:strokeColor="#A78BFA" android:strokeWidth="1.5" android:fillColor="#00000000" android:strokeAlpha="0.4"/>
    <path android:pathData="M75,114m-1,0a1,1 0,1,1 2,0a1,1 0,1,1 -2,0"
        android:fillColor="#A78BFA" android:fillAlpha="0.4"/>

</vector>
