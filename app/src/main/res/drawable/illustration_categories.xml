    <path android:pathData="M70,155m-3,0a3,3 0,1,1 6,0a3,3 0,1,1 -6,0"
        android:fillColor="#67E8F9" android:fillAlpha="0.5"/>
    <path android:pathData="M175,155m-2,0a2,2 0,1,1 4,0a2,2 0,1,1 -4,0"
