        </aapt:attr>
    </path>
    <!-- Icon in bottom-left: book/pages -->
    <path android:pathData="M94,108 L106,108 L106,122 L100,119 L94,122 Z"
        android:strokeColor="#DDD6FE" android:strokeWidth="1.2" android:fillColor="#00000000" android:strokeAlpha="0.7"/>

    <!-- Bottom-right tile (teal) -->
    <path android:pathData="M128,100 L152,100 Q154,100 154,102 L154,126 Q154,128 152,128 L128,128 Q126,128 126,126 L126,102 Q126,100 128,100 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="126"
                android:startY="100"
                android:endX="154"
                android:endY="128">
                <item android:offset="0" android:color="#FF0D9488"/>
                <item android:offset="1" android:color="#FF0F766E"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- Icon in bottom-right: globe dot -->
    <path android:pathData="M140,114m-5,0a5,5 0,1,1 10,0a5,5 0,1,1 -10,0"
        android:strokeColor="#99F6E4" android:strokeWidth="1" android:fillColor="#00000000" android:strokeAlpha="0.7"/>
    <path android:pathData="M135,114 L145,114"
        android:strokeColor="#99F6E4" android:strokeWidth="0.8" android:strokeAlpha="0.5"/>
    <path android:pathData="M140,109 L140,119"
        android:strokeColor="#99F6E4" android:strokeWidth="0.8" android:strokeAlpha="0.5"/>

    <!-- ===== ORBITAL RING ===== -->
    <group
        android:pivotX="120"
        android:pivotY="94"
        android:rotation="18">
        <path
            android:pathData="M120,94m-65,0a65,30 0,1,1 130,0a65,30 0,1,1 -130,0"
            android:strokeColor="#6366F1"
            android:strokeWidth="1"
            android:fillColor="#00000000"
            android:strokeAlpha="0.3"/>
    </group>

    <!-- ===== ORBITAL RING 2 ===== -->
    <group
        android:pivotX="120"
        android:pivotY="94"
        android:rotation="-12">
        <path
            android:pathData="M120,94m-58,0a58,26 0,1,1 116,0a58,26 0,1,1 -116,0"
            android:strokeColor="#06B6D4"
            android:strokeWidth="0.8"
            android:fillColor="#00000000"
            android:strokeAlpha="0.25"/>
    </group>

    <!-- ===== FLOATING ORBS ===== -->
    <path android:pathData="M55,45m-8,0a8,8 0,1,1 16,0a8,8 0,1,1 -16,0">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                android:centerX="55" android:centerY="45"
                android:gradientRadius="8">
                <item android:offset="0" android:color="#CCA78BFA"/>
                <item android:offset="1" android:color="#668B5CF6"/>
            </gradient>
        </aapt:attr>
    </path>
    <path android:pathData="M190,55m-7,0a7,7 0,1,1 14,0a7,7 0,1,1 -14,0">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                android:centerX="190" android:centerY="55"
                android:gradientRadius="7">
                <item android:offset="0" android:color="#CC22D3EE"/>
                <item android:offset="1" android:color="#6606B6D4"/>
            </gradient>
        </aapt:attr>
    </path>
    <path android:pathData="M45,140m-6,0a6,6 0,1,1 12,0a6,6 0,1,1 -12,0">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                android:centerX="45" android:centerY="140"
                android:gradientRadius="6">
                <item android:offset="0" android:color="#CC0D9488"/>
                <item android:offset="1" android:color="#660D9488"/>
            </gradient>
        </aapt:attr>
    </path>
    <path android:pathData="M200,130m-5,0a5,5 0,1,1 10,0a5,5 0,1,1 -10,0"
        android:fillColor="#818CF8" android:fillAlpha="0.5"/>

